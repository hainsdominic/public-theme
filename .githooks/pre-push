#!/bin/bash

# Pre-push hook: pull latest Shopify theme state before pushing,
# then deploy the theme to Shopify after push succeeds.

STORE="cafepublic.myshopify.com"
THEME="183131996466"
REPO_ROOT="$(git rev-parse --show-toplevel)"

deploy_to_shopify() {
  echo "🚀 Deploying theme to Shopify ($STORE)..."
  if shopify theme push --store "$STORE" --theme "$THEME" --path "$REPO_ROOT" --allow-live; then
    echo "✅ Theme deployed to Shopify."
  else
    echo "⚠️  Shopify deploy failed — push succeeded but theme was not updated."
  fi
}

# Skip with: SKIP_SHOPIFY_PULL=1 git push
if [[ "$SKIP_SHOPIFY_PULL" == "1" ]]; then
  echo "⏭️  Skipping Shopify pull (SKIP_SHOPIFY_PULL=1)"
  exit 0
fi

remote_sha=""
while read -r local_ref local_sha remote_ref remote_sha_line; do
  remote_sha="$remote_sha_line"
done

echo "🔄 Pulling latest theme from Shopify ($STORE)..."

if ! command -v shopify &>/dev/null; then
  echo "⚠️  Shopify CLI not found, skipping pull. Be careful with template JSON files."
  exit 0
fi

if ! shopify theme pull --store "$STORE" --theme "$THEME" --path "$REPO_ROOT" 2>&1; then
  echo "⚠️  Could not pull from Shopify. Continuing push — verify manually if client may have made editor changes."
  exit 0
fi

changed_files=$(git diff --name-only)
if [[ -z "$changed_files" ]]; then
  echo "✅ Shopify and git are in sync. Pushing..."
  deploy_to_shopify &
  exit 0
fi

if [[ -n "$remote_sha" && "$remote_sha" != "0000000000000000000000000000000000000000" ]]; then
  pushed_files=$(git diff --name-only "$remote_sha" HEAD 2>/dev/null)
else
  pushed_files=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)
fi

unexpected=""
while IFS= read -r file; do
  if ! echo "$pushed_files" | grep -qxF "$file"; then
    unexpected+="  $file"$'\n'
  fi
done <<< "$changed_files"

if [[ -n "$unexpected" ]]; then
  echo ""
  echo "❌ Shopify has changes that aren't in git yet!"
  echo ""
  echo "$unexpected"
  echo "Commit these first, then push again."
  exit 1
fi

echo "✅ Shopify pull only touched files in the current commit — restoring and pushing..."
git checkout -- .
deploy_to_shopify &

exit 0
